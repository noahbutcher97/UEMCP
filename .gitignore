# Node.js (server/)
node_modules/
dist/
*.tsbuildinfo
.env
.env.local

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# UE plugin build artifacts (match any nesting under plugin/)
plugin/**/Binaries/
plugin/**/Intermediate/
plugin/**/DerivedDataCache/
*.sln
*.vcxproj*

# Logs
*.log

# MCP config (per-machine — template is .mcp.json.example)
.mcp.json
.claude/settings.local.json

# Session-local documentation (handoffs, audits, testing logs, research)
# These are artifacts of individual agent dispatches, not product docs.
# Kept on disk for local reference; not tracked in the public repo.
docs/handoffs/
docs/audits/
docs/testing/
docs/research/

# Sanitization scratch — these files contain literal sensitive tokens.
# Used during one-off filter-repo passes; never tracked.
.filter-repo-replacements.txt
.filter-repo-mailmap.txt
.git-rewrite/

# Backup bundles
*.bundle
