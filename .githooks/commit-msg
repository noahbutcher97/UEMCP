#!/usr/bin/env bash
# Commit-msg hook: scan the commit message for forbidden tokens.
# git passes the path to the message file as $1.
set -u

here="$(cd "$(dirname "$0")" && pwd)"
msg_file="$1"

[[ -f "$msg_file" ]] || exit 0

# Strip git's commented '#' lines (those don't go into the commit object)
sed '/^#/d' "$msg_file" | "$here/check-tokens.sh" --label "commit message"
