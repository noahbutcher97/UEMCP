#!/usr/bin/env bash
# Pre-push: scan outgoing commits (file diff + commit messages) for NDA
# codenames listed in .git/info/forbidden-tokens (per-checkout, untracked).
#
# This is the only enforcement layer. Free to commit anything locally;
# the gate is at push time when content actually goes public.
#
# Bypass: git push --no-verify
set -u

# Force UTF-8 locale — empty LANG on Git Bash for Windows causes
# `grep -F -i -f` to silently miss matches on lines containing
# multi-byte chars (Unicode box-drawing in CLAUDE.md, em-dashes in
# READMEs). Without this export, the pre-push gate is leakier than
# it appears. Discovered by DOCS-GROOMING worker 2026-04-26 while
# wiring the matching .githooks/pre-commit hook.
export LC_ALL=C.UTF-8

tokens=".git/info/forbidden-tokens"
if [[ ! -f "$tokens" ]]; then
  echo "" >&2
  echo "⚠ UEMCP NDA-codename hook: .git/info/forbidden-tokens is ABSENT in this checkout." >&2
  echo "  Per CLAUDE.md §Public-Repo Hygiene, this file is per-checkout one-time setup." >&2
  echo "  Without it, the codename gate is not active in this checkout." >&2
  echo "  Action: populate .git/info/forbidden-tokens with one codename per line." >&2
  echo "  Continuing without gate (this hook will exit 0)." >&2
  echo "" >&2
  exit 0
fi

literals="$(mktemp)"
regexes="$(mktemp)"
trap 'rm -f "$literals" "$regexes"' EXIT

while IFS= read -r line || [[ -n "$line" ]]; do
  [[ -z "${line// /}" || "${line:0:1}" == "#" ]] && continue
  if [[ "$line" == regex:* ]]; then
    printf '%s\n' "${line#regex:}" >> "$regexes"
  else
    printf '%s\n' "$line" >> "$literals"
  fi
done < "$tokens"

if [[ ! -s "$literals" && ! -s "$regexes" ]]; then
  exit 0
fi

zero="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_sha" == "$zero" ]] && continue   # branch deletion

  if [[ "$remote_sha" == "$zero" ]]; then
    content="$(git log -p --no-color "$local_sha" 2>/dev/null; git log --format='%B' "$local_sha" 2>/dev/null)"
    range_label="new-branch $local_sha"
  else
    content="$(git log -p --no-color "${remote_sha}..${local_sha}" 2>/dev/null; git log --format='%B' "${remote_sha}..${local_sha}" 2>/dev/null)"
    range_label="${remote_sha}..${local_sha}"
  fi

  [[ -z "$content" ]] && continue

  hits=""
  if [[ -s "$literals" ]]; then
    m="$(printf '%s\n' "$content" | grep -F -i -n -f "$literals" 2>/dev/null | head -10 || true)"
    [[ -n "$m" ]] && hits+="$m"$'\n'
  fi
  if [[ -s "$regexes" ]]; then
    m="$(printf '%s\n' "$content" | grep -E -i -n -f "$regexes" 2>/dev/null | head -10 || true)"
    [[ -n "$m" ]] && hits+="$m"$'\n'
  fi

  if [[ -n "$hits" ]]; then
    {
      echo ""
      echo "✗ Push blocked: NDA codename detected in outgoing diff ($range_label)"
      echo ""
      printf '%s' "$hits"
      echo ""
      echo "  Edit content to remove/replace, or bypass with 'git push --no-verify'."
      echo "  Token list: .git/info/forbidden-tokens"
      echo ""
    } >&2
    exit 1
  fi
done

exit 0
